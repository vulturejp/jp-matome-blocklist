{
  "name": "jp-matome-blocklist",
  "version": "0.1.0",
  "private": true,
  "description": "Collect Japanese 5ch/2ch matome blog URLs from antenna sites and publish blocklists for uBlock Origin, AdGuard, and uBlacklist.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "build": "tsc --outDir dist --noEmit false",
    "generate": "npm run build && node scripts/generate.mjs",
    "pretest": "tsc --outDir dist-test --noEmit false",
    "test": "node --test test/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
